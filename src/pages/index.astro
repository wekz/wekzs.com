---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Veljko Aleksić — QA Automation Engineer" wide>
  <section class="home-hero page-home">
    <div class="home-content">
      <h1>Veljko Aleksić</h1>
      <p class="home-role">QA Engineer at <a href="/work" class="home-role-link">ecd.rs</a></p>
      <p class="home-desc">Obsessed with how things work and why they break.</p>
      <button class="home-cmd-hint" id="open-cmd" aria-label="Open command palette">
        Press <span class="home-cmd-keys"><kbd id="cmd-mod-key">⌘</kbd><kbd>K</kbd></span><span class="home-cmd-tap" style="display:none"> </span>to start <span class="arrow">→</span>
      </button>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('open-cmd')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-command-palette'));
    });

    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform) ||
                  (navigator as any).userAgentData?.platform === 'macOS';
    if (!isMac) {
      const modKey = document.getElementById('cmd-mod-key');
      if (modKey) modKey.textContent = 'Ctrl';
    }
  });
</script>

