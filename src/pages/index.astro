---
import Layout from '@/layouts/Layout.astro';
import { SITE } from '@/config/site';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: Astro.site?.href,
  jobTitle: SITE.role,
  description: SITE.description,
  sameAs: [SITE.github, SITE.linkedin, SITE.hevy],
};
---

<Layout title="Veljko Aleksić" wide jsonLd={personSchema}>
  <section class="home-hero page-home">
    <div class="home-main">
      <div class="home-left">
        <div class="home-badge" aria-label="// open for contribution">
          <span class="home-badge-comment" data-text="//"></span><span class="home-badge-text" data-text="open_to_collaborate"></span>
        </div>
        <h1><span class="home-name-v">Veljko</span> <span class="home-name-a">Aleksić</span></h1>
        <p class="home-role">QA Engineer at <a href="/work" class="home-role-link">ecd.rs</a></p>
        <p class="home-desc">Obsessed with how things work and why they break.</p>
        <button class="home-cmd-hint" id="open-cmd" aria-label="Open command palette">
          Press <span class="home-cmd-keys"><kbd class="cmd-mod-key"><span class="mod-mac">⌘</span><span class="mod-other">Ctrl</span></kbd><kbd>K</kbd></span> to start <span class="arrow">→</span>
        </button>
      </div>
      <div class="home-right">
        <div class="home-meta-item">
          <span class="home-meta-label">LOCAL</span>
          <span class="home-meta-value">Belgrade · <span id="home-clock"></span></span>
        </div>
        <div class="home-meta-item">
          <span class="home-meta-label">FOCUS</span>
          <span class="home-meta-value">Reliability · Quality / Security</span>
        </div>
        <div class="home-meta-item">
          <span class="home-meta-label">CAREER</span>
          <span class="home-meta-value">2018 · present</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('open-cmd')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-command-palette'));
    });

    // Type out the badge like a real dev at a keyboard: type the // (purple),
    // grey it out VS Code style, then fumble the word — typo, pause, backspace,
    // retype — with an uneven human rhythm.
    const badge = document.querySelector('.home-badge');
    const commentEl = badge?.querySelector('.home-badge-comment');
    const textEl = badge?.querySelector('.home-badge-text');
    const cmdHint = document.querySelector('.home-cmd-hint');
    if (commentEl instanceof HTMLElement && textEl instanceof HTMLElement) {
      // Run the intro only on a genuine document load — not on View Transition
      // navigations. The flag lives on window: survives soft swaps, resets on a
      // real hard reload (no storage = no caching).
      const firstLoad = !(window as any).__homeIntroPlayed;
      (window as any).__homeIntroPlayed = true;

      if (!firstLoad) {
        // Soft navigation back to home — show the finished state instantly.
        commentEl.textContent = '//';
        badge?.classList.add('is-typed');
        textEl.textContent = ' open_for_contribution';
        cmdHint?.classList.add('shown');
      } else {
      commentEl.textContent = '';
      textEl.textContent = '';
      const wait = (ms: number) => new Promise(r => setTimeout(r, ms));
      const rnd = (min: number, max: number) => min + Math.random() * (max - min);

      const typeStr = async (el: HTMLElement, str: string) => {
        for (const ch of str) {
          el.textContent += ch;
          await wait(rnd(55, 130));
        }
      };
      const deleteN = async (el: HTMLElement, n: number) => {
        for (let i = 0; i < n; i++) {
          el.textContent = (el.textContent || '').slice(0, -1);
          await wait(rnd(40, 80));
        }
      };

      // "Press to start" flicks on once the badge line is finished.
      (async () => {
        await wait(rnd(700, 1000));
        await typeStr(commentEl, '//');
        badge?.classList.add('is-typed');        // // settles to grey immediately
        await wait(rnd(150, 250));
        await typeStr(textEl, ' open_to_c');     // wrong word starting…
        await wait(rnd(650, 850));               // well, that too, but...
        await deleteN(textEl, 4);                // erase "to_c" back to open_
        await wait(rnd(150, 250));
        await typeStr(textEl, 'for_contribution'); // -> open_for_contribution
        await wait(rnd(250, 400));               // beat, then hit the lights
        cmdHint?.classList.add('lit');
      })();
      }
    }

    const clockEl = document.getElementById('home-clock');
    if (clockEl) {
      const fmt = new Intl.DateTimeFormat('en-GB', {
        timeZone: 'Europe/Belgrade',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      });
      const tick = () => { clockEl.textContent = fmt.format(new Date()); };
      tick();
      const now = new Date();
      setTimeout(() => { tick(); setInterval(tick, 60000); }, (60 - now.getSeconds()) * 1000);
    }
  });
</script>
