---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — wekzs" description="Writing on QA automation, tooling, and software quality.">
  <section class="page-blog">
    <h1 class="gradient-title g-pink">Stories. Notes. Lessons.</h1>

    {posts.length === 0 ? (
      <p class="empty">No posts yet. Check back soon.</p>
    ) : (
      <ul>
        {posts.map(post => (
          <li>
            <a href={`/blog/${post.id}`}>
              <div class="post-info">
                <span class="post-title">{post.data.title}</span>
                <span class="post-desc">{post.data.description}</span>
              </div>
              <time>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
