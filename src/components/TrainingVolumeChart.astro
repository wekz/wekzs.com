---
import { getMonthlyVolume } from '@/lib/hevy';

const MONTHS = 12;
const buckets = await getMonthlyVolume(MONTHS);

// ── Geometry ──
const W = 800, H = 200, PX = 6, PT = 18, PB = 26;
const max = Math.max(...buckets.map(b => b.volume), 1);
const stepX = (W - PX * 2) / (MONTHS - 1);
const pts = buckets.map((b, i) => [
  PX + i * stepX,
  PT + (H - PT - PB) * (1 - b.volume / max),
] as [number, number]);

function smooth(p: [number, number][]) {
  if (p.length < 2) return p.length ? `M${p[0][0]},${p[0][1]}` : '';
  let d = `M${p[0][0].toFixed(1)},${p[0][1].toFixed(1)}`;
  for (let i = 0; i < p.length - 1; i++) {
    const p0 = p[i - 1] ?? p[i], p1 = p[i], p2 = p[i + 1], p3 = p[i + 2] ?? p2;
    const c1x = p1[0] + (p2[0] - p0[0]) / 6, c1y = p1[1] + (p2[1] - p0[1]) / 6;
    const c2x = p2[0] - (p3[0] - p1[0]) / 6, c2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += ` C${c1x.toFixed(1)},${c1y.toFixed(1)} ${c2x.toFixed(1)},${c2y.toFixed(1)} ${p2[0].toFixed(1)},${p2[1].toFixed(1)}`;
  }
  return d;
}
const line = smooth(pts);
const area = `${line} L${pts[pts.length - 1][0].toFixed(1)},${H - PB} L${pts[0][0].toFixed(1)},${H - PB} Z`;
const uid = 'tv-' + Math.random().toString(36).slice(2, 8);
---

<figure class="volchart">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Monthly training volume">
    <defs>
      <linearGradient id={uid} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--dracula-green)" stop-opacity="0.35" />
        <stop offset="100%" stop-color="var(--dracula-green)" stop-opacity="0" />
      </linearGradient>
    </defs>

    <line class="vc-crosshair" x1="0" y1={PT} x2="0" y2={H - PB} />
    <path d={area} fill={`url(#${uid})`} />
    <path d={line} fill="none" stroke="var(--dracula-green)" stroke-width="2"
      stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" />

    {pts.map((p) => (
      <circle class="vc-dot" cx={p[0]} cy={p[1]} r="0" fill="var(--dracula-green)" />
    ))}

    {buckets.map((b) => (
      <text class="vc-xlabel" x={pts[buckets.indexOf(b)][0]} y={H - 8} text-anchor="middle">{b.label}</text>
    ))}

    {buckets.map((b, i) => (
      <rect
        class="vc-hit"
        x={pts[i][0] - stepX / 2}
        y="0"
        width={stepX}
        height={H}
        data-i={i}
        data-x={pts[i][0]}
        data-y={pts[i][1]}
        data-label={`${b.label}: ${Math.round(b.volume).toLocaleString()} kg`}
      />
    ))}
  </svg>

  <div class="vc-tooltip" aria-hidden="true"></div>
</figure>

<script>
  function initVolChart() {
    const fig = document.querySelector('.volchart') as HTMLElement | null;
    const svg = fig?.querySelector('svg') as SVGSVGElement | null;
    const tip = fig?.querySelector('.vc-tooltip') as HTMLElement | null;
    const cross = fig?.querySelector('.vc-crosshair') as SVGLineElement | null;
    const dots = fig?.querySelectorAll('.vc-dot');
    if (!fig || !svg || !tip || !cross || !dots) return;

    const VB_W = 800, VB_H = 200;

    fig.querySelectorAll('.vc-hit').forEach(hit => {
      hit.addEventListener('mouseenter', () => {
        const i = parseInt((hit as HTMLElement).dataset.i ?? '0');
        const x = parseFloat((hit as HTMLElement).dataset.x ?? '0');
        const y = parseFloat((hit as HTMLElement).dataset.y ?? '0');
        cross.setAttribute('x1', String(x));
        cross.setAttribute('x2', String(x));
        cross.classList.add('show');
        dots.forEach((d, di) => d.setAttribute('r', di === i ? '4' : '0'));

        const rect = svg.getBoundingClientRect();
        const px = (x / VB_W) * rect.width;
        const py = (y / VB_H) * rect.height;
        tip.textContent = (hit as HTMLElement).dataset.label ?? '';
        tip.style.left = `${px}px`;
        tip.style.top = `${py - 12}px`;
        tip.classList.add('show');
      });
    });

    svg.addEventListener('mouseleave', () => {
      cross.classList.remove('show');
      tip.classList.remove('show');
      dots.forEach(d => d.setAttribute('r', '0'));
    });
  }

  document.addEventListener('astro:page-load', initVolChart);
</script>
