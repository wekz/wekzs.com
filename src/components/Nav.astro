---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/uses', label: 'Uses' },
];

const current = Astro.url.pathname;
---

<nav>
  <a href="/" class="logo" aria-label="Home" draggable="false">W</a>

  <ul id="nav-list">
    <span class="nav-highlight" aria-hidden="true"></span>
    {links.map(link => (
      <li>
        <a
          href={link.href}
          draggable="false"
          class={current === link.href || current.startsWith(link.href) ? 'active' : ''}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-right">
    <ThemeToggle />
    <button id="cmd-trigger" aria-label="Open command palette" title="Open command palette (⌘K)">
      ⌘
    </button>
  </div>

  <!-- Mobile only: search icon opens the command palette (theme, search, nav all live there) -->
  <button id="nav-mobile-cmd" aria-label="Open command palette">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
  </button>
</nav>

<script>
  function initNav() {
    // Mobile: single command icon opens the palette
    document.getElementById('nav-mobile-cmd')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-command-palette'));
    });

    const list = document.getElementById('nav-list');
    const highlight = list?.querySelector('.nav-highlight') as HTMLElement | null;
    const anchors = list?.querySelectorAll('a');
    const activeAnchor = list?.querySelector('a.active') as HTMLElement | null;

    function moveHighlight(el: HTMLElement, animate = true) {
      if (!highlight) return;
      if (!animate) highlight.style.transition = 'none';
      highlight.style.width = `${el.offsetWidth}px`;
      highlight.style.height = `${el.offsetHeight}px`;
      highlight.style.left = `${el.offsetLeft}px`;
      highlight.style.top = `${el.offsetTop}px`;
      highlight.style.opacity = '1';
      if (!animate) {
        void highlight.offsetWidth;
        highlight.style.transition = '';
      }
    }

    if (activeAnchor) moveHighlight(activeAnchor, false);

    anchors?.forEach(a => {
      a.addEventListener('mouseenter', () => moveHighlight(a as HTMLElement));
    });

    list?.addEventListener('mouseleave', () => {
      if (activeAnchor) moveHighlight(activeAnchor);
      else if (highlight) highlight.style.opacity = '0';
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  nav a,
  nav a *,
  .logo {
    cursor: pointer !important;
    user-select: none;
    -webkit-user-select: none;
    /* Links are draggable by default; on mousedown Chrome starts drag-detection
       and the cursor flashes to the default arrow for a frame. Disable dragging
       so the pointer cursor stays steady on click. */
    -webkit-user-drag: none;
  }

  nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.5rem 3rem;
    position: relative;
  }

  .logo {
    justify-self: start;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
    cursor: pointer;
  }

  ul {
    position: relative;
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
  }

  .nav-highlight {
    position: absolute;
    top: 0;
    left: 0;
    height: 0;
    border-radius: 6px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    box-sizing: border-box;
    opacity: 0;
    transition: left 0.2s ease, width 0.2s ease, opacity 0.15s ease;
    pointer-events: none;
    cursor: pointer;
  }

  li a {
    position: relative;
    z-index: 2;
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    cursor: pointer;
    pointer-events: auto;
    transition: color 0.15s;
  }

  li a:hover,
  li a.active {
    color: var(--accent);
  }

  /* Light mode: hover color reads thinner than on dark, so add a touch of weight */
  :global([data-theme="light"]) li a:hover { font-weight: 600; }

  li a.active::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 1.5px;
    background: var(--accent);
    border-radius: 2px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-self: end;
  }

  #cmd-trigger {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--text-muted);
    padding: 4px 6px;
    border-radius: 4px;
    line-height: 1;
    transition: color 0.15s;
  }

  #cmd-trigger:hover {
    color: var(--accent);
  }

  /* Mobile command icon — hidden on desktop, shown via media query */
  #nav-mobile-cmd {
    display: none;
    justify-self: end;
    align-self: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px;
    border-radius: 6px;
    line-height: 0;
    transition: color 0.15s;
  }
  #nav-mobile-cmd:hover,
  #nav-mobile-cmd:active { color: var(--accent); }

  @media (max-width: 600px) {
    nav { align-items: center; }
    .logo { align-self: center; font-size: 1.45rem; margin-left: -1px; }
    #nav-mobile-cmd { display: flex !important; transform: translateY(-2px); }
  }
</style>
