---
// Dual-area training chart: monthly lifting volume (green) overlaid with
// workout count (purple). Data comes from the Hevy API at build time.
// Hovering snaps a crosshair to the nearest month and shows both values.
import { getHevyData } from '@/lib/hevy';

const MONTHS = 12;
const { monthlyVolume: buckets } = await getHevyData(MONTHS);

// ── Viewbox geometry (unitless; SVG scales to container width) ──
const VB = { w: 800, h: 260, padX: 8, padTop: 24, padBottom: 40 };
const plotH = VB.h - VB.padTop - VB.padBottom;
const baseY = VB.h - VB.padBottom;
const stepX = (VB.w - VB.padX * 2) / (MONTHS - 1);

const maxVolume = Math.max(...buckets.map(b => b.volume), 1);
const maxCount  = Math.max(...buckets.map(b => b.count), 1);

// One point per month, with a y-coordinate for each series.
const points = buckets.map((b, i) => ({
  x:      VB.padX + i * stepX,
  volY:   VB.padTop + plotH * (1 - b.volume / maxVolume),
  cntY:   VB.padTop + plotH * (1 - b.count / maxCount),
  label:  b.label,
  volume: Math.round(b.volume).toLocaleString(),
  count:  b.count,
}));

// Catmull-Rom -> cubic Bézier, for a smooth line through every point.
function smoothPath(coords: { x: number; y: number }[]): string {
  if (coords.length < 2) return '';
  const pt = (i: number) => coords[Math.max(0, Math.min(coords.length - 1, i))];
  let d = `M${pt(0).x.toFixed(1)},${pt(0).y.toFixed(1)}`;
  for (let i = 0; i < coords.length - 1; i++) {
    const p0 = pt(i - 1), p1 = pt(i), p2 = pt(i + 1), p3 = pt(i + 2);
    const c1x = p1.x + (p2.x - p0.x) / 6, c1y = p1.y + (p2.y - p0.y) / 6;
    const c2x = p2.x - (p3.x - p1.x) / 6, c2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C${c1x.toFixed(1)},${c1y.toFixed(1)} ${c2x.toFixed(1)},${c2y.toFixed(1)} ${p2.x.toFixed(1)},${p2.y.toFixed(1)}`;
  }
  return d;
}

// Close a line path down to the baseline to make a fillable area.
const toArea = (line: string) =>
  `${line} L${points.at(-1)!.x.toFixed(1)},${baseY} L${points[0].x.toFixed(1)},${baseY} Z`;

const volLine = smoothPath(points.map(p => ({ x: p.x, y: p.volY })));
const cntLine = smoothPath(points.map(p => ({ x: p.x, y: p.cntY })));

const uid = 'tc-' + Math.random().toString(36).slice(2, 8);
---

<div class="training-card">
  <figure class="tchart">
    <svg viewBox={`0 0 ${VB.w} ${VB.h}`} role="img" aria-label="Monthly training volume and workout count">
      <defs>
        <linearGradient id={`${uid}-vol`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="var(--dracula-green)"  stop-opacity="0.35" />
          <stop offset="100%" stop-color="var(--dracula-green)"  stop-opacity="0" />
        </linearGradient>
        <linearGradient id={`${uid}-cnt`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="var(--dracula-purple)" stop-opacity="0.28" />
          <stop offset="100%" stop-color="var(--dracula-purple)" stop-opacity="0" />
        </linearGradient>
      </defs>

      {/* Area fills */}
      <path d={toArea(cntLine)} fill={`url(#${uid}-cnt)`} />
      <path d={toArea(volLine)} fill={`url(#${uid}-vol)`} />

      {/* Smooth lines */}
      <path d={cntLine} fill="none" stroke="var(--dracula-purple)"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
      <path d={volLine} fill="none" stroke="var(--dracula-green)"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />

      {/* Crosshair + dots, revealed on hover */}
      <line class="tc-crosshair" x1="0" y1={VB.padTop} x2="0" y2={baseY} />
      <circle class="tc-dot tc-dot-cnt" cx="0" cy="0" r="4.5" fill="var(--dracula-purple)" />
      <circle class="tc-dot tc-dot-vol" cx="0" cy="0" r="4.5" fill="var(--dracula-green)" />

      {/* X-axis month labels */}
      {points.map(p => (
        <text class="tc-xlabel" x={p.x} y={VB.h - 10} text-anchor="middle">{p.label}</text>
      ))}

      {/* Invisible hit zones, one per month */}
      {points.map((p, i) => (
        <rect class="tc-hit" x={p.x - stepX / 2} y="0" width={stepX} height={VB.h}
          data-x={p.x} data-voly={p.volY} data-cnty={p.cntY}
          data-label={p.label} data-volume={p.volume} data-count={p.count} />
      ))}
    </svg>

    <div class="tc-tooltip" aria-hidden="true">
      <div class="tc-tip-date"></div>
      <div class="tc-tip-row">
        <span class="tc-tip-dot" style="background:var(--dracula-green)"></span>
        <span class="tc-tip-key">Volume</span>
        <span class="tc-tip-vol"></span>
      </div>
      <div class="tc-tip-row">
        <span class="tc-tip-dot" style="background:var(--dracula-purple)"></span>
        <span class="tc-tip-key">Workouts</span>
        <span class="tc-tip-cnt"></span>
      </div>
    </div>
  </figure>

  <div class="tc-legend">
    <span class="tc-legend-item">
      <span class="tc-legend-dot" style="background:var(--dracula-green)"></span>
      Monthly Volume (kg)
    </span>
    <span class="tc-legend-item">
      <span class="tc-legend-dot" style="background:var(--dracula-purple)"></span>
      Workouts / month
    </span>
  </div>
</div>

<script>
  const VB_W = 800, VB_H = 260;

  function initTrainingChart() {
    const fig = document.querySelector<HTMLElement>('.tchart');
    const svg = fig?.querySelector('svg');
    const tip = fig?.querySelector<HTMLElement>('.tc-tooltip');
    if (!fig || !svg || !tip) return;

    const cross  = svg.querySelector<SVGLineElement>('.tc-crosshair')!;
    const dotVol = svg.querySelector<SVGCircleElement>('.tc-dot-vol')!;
    const dotCnt = svg.querySelector<SVGCircleElement>('.tc-dot-cnt')!;
    const els = {
      date: tip.querySelector<HTMLElement>('.tc-tip-date')!,
      vol:  tip.querySelector<HTMLElement>('.tc-tip-vol')!,
      cnt:  tip.querySelector<HTMLElement>('.tc-tip-cnt')!,
    };

    function showPoint(hit: HTMLElement) {
      const rect = svg!.getBoundingClientRect();
      const x    = +hit.dataset.x!;
      const volY = +hit.dataset.voly!;
      const cntY = +hit.dataset.cnty!;

      cross.setAttribute('x1', String(x));
      cross.setAttribute('x2', String(x));
      dotVol.setAttribute('cx', String(x));
      dotVol.setAttribute('cy', String(volY));
      dotCnt.setAttribute('cx', String(x));
      dotCnt.setAttribute('cy', String(cntY));

      els.date.textContent = hit.dataset.label ?? '';
      els.vol.textContent  = `${hit.dataset.volume} kg`;
      els.cnt.textContent  = hit.dataset.count ?? '';

      // Pin tooltip near the crosshair, flipping side past the midpoint.
      const px = (x / VB_W) * rect.width;
      const py = (Math.min(volY, cntY) / VB_H) * rect.height;
      tip!.style.left      = `${px}px`;
      tip!.style.top       = `${py}px`;
      tip!.style.transform = x > VB_W / 2
        ? 'translate(calc(-100% - 14px), -50%)'
        : 'translate(14px, -50%)';

      fig!.classList.add('tc-active');
    }

    fig.querySelectorAll<HTMLElement>('.tc-hit').forEach(hit =>
      hit.addEventListener('mouseenter', () => showPoint(hit))
    );
    svg.addEventListener('mouseleave', () => fig.classList.remove('tc-active'));
  }

  document.addEventListener('astro:page-load', initTrainingChart);
</script>
