<div id="cmd-overlay" aria-hidden="true">
  <div id="cmd-palette" role="dialog" aria-modal="true" aria-label="Command palette">
    <input id="cmd-input" type="text" placeholder="Type a command or search..." autocomplete="off" spellcheck="false" />
    <div class="cmd-divider"></div>
    <div id="cmd-list"></div>
  </div>
</div>

<script>
  import { navigate } from 'astro:transitions/client';
  // SITE constants are build-time only; we inline the values we need here
  // because this <script> runs in the browser (no access to Astro imports).
  const EMAIL     = 'hello@wekzs.com';
  const GITHUB    = 'https://github.com/wekz/wekzs.com';

  // Lazy getters — always return the CURRENT DOM node, never a stale reference
  const getOverlay = () => document.getElementById('cmd-overlay')!;
  const getInput = () => document.getElementById('cmd-input') as HTMLInputElement;
  const getList = () => document.getElementById('cmd-list')!;

  type Command = {
    group: string;
    label: string;
    shortcut: string[];
    icon: string;
    anim: string;
    action: () => void;
  };

  const icons: Record<string, string> = {
    link:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
    mail:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    code:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    home:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    user:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`,
    edit:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    briefcase: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
    file:      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>`,
    wrench:    `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  };

  const commands: Command[] = [
    { group: 'general', label: 'Copy Link',   shortcut: ['L'],      icon: icons.link,      anim: 'shake',  action: () => { navigator.clipboard.writeText(window.location.href); close(); showToast('Link copied!'); }},
    { group: 'general', label: 'Send Email',  shortcut: ['E'],      icon: icons.mail,      anim: 'fly',    action: () => { window.location.href = `mailto:${EMAIL}`; close(); }},
    { group: 'general', label: 'View Source', shortcut: ['S'],      icon: icons.code,      anim: 'blink',  action: () => { window.open(GITHUB, '_blank'); close(); }},
    { group: 'goto',    label: 'Home',        shortcut: ['G', 'H'], icon: icons.home,      anim: 'bounce', action: () => { close(); navigate('/'); }},
    { group: 'goto',    label: 'About',       shortcut: ['G', 'A'], icon: icons.user,      anim: 'pulse',  action: () => { close(); navigate('/about'); }},
    { group: 'goto',    label: 'Blog',        shortcut: ['G', 'B'], icon: icons.edit,      anim: 'write',  action: () => { close(); navigate('/blog'); }},
    { group: 'goto',    label: 'Work',        shortcut: ['G', 'W'], icon: icons.briefcase, anim: 'swing',  action: () => { close(); navigate('/work'); }},
    { group: 'goto',    label: 'CV',          shortcut: ['G', 'C'], icon: icons.file,      anim: 'slide',  action: () => { close(); navigate('/cv'); }},
    { group: 'goto',    label: 'Uses',        shortcut: ['G', 'U'], icon: icons.wrench,    anim: 'spin',   action: () => { close(); navigate('/uses'); }},
  ];

  let activeIndex = 0;
  let isOpen = false;

  function open() {
    const overlay = getOverlay();
    const input = getInput();
    if (!overlay || !input) return;
    isOpen = true;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('visible');
    input.value = '';
    renderList('');
    // Don't auto-focus on touch devices — it opens the keyboard
    if (window.matchMedia('(hover: hover)').matches) {
      setTimeout(() => input.focus(), 30);
    }
  }

  function close() {
    const overlay = getOverlay();
    isOpen = false;
    overlay?.setAttribute('aria-hidden', 'true');
    overlay?.classList.remove('visible');
    // Drop focus from the search input so global g-shortcuts work afterwards
    getInput()?.blur();
  }

  function showToast(msg: string) {
    const t = document.createElement('div');
    t.className = 'cmd-toast';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.classList.add('show'), 10);
    setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 2000);
  }

  function getFiltered(query: string): Command[] {
    if (!query) return commands;
    const q = query.toLowerCase().replace(/\s+/g, '');
    return commands.filter(c =>
      c.label.toLowerCase().replace(/\s+/g, '').includes(q) ||
      c.shortcut.join('').toLowerCase().includes(q)
    );
  }

  function renderList(query: string) {
    const list = getList();
    if (!list) return;
    const filtered = getFiltered(query);
    activeIndex = 0;

    if (filtered.length === 0) {
      list.innerHTML = `<div class="cmd-empty">No results for "${query}"</div>`;
      return;
    }

    const general = filtered.filter(c => c.group === 'general');
    const goto = filtered.filter(c => c.group === 'goto');

    let html = '';

    if (general.length > 0) {
      html += `<div class="cmd-group-label">GENERAL</div>`;
      general.forEach(cmd => {
        const idx = filtered.indexOf(cmd);
        html += itemHTML(cmd, idx, idx === 0);
      });
    }

    if (goto.length > 0) {
      html += `<div class="cmd-group-label">GO TO</div>`;
      goto.forEach(cmd => {
        const idx = filtered.indexOf(cmd);
        html += itemHTML(cmd, idx, idx === 0 && general.length === 0);
      });
    }

    list.innerHTML = html;

    // Sliding highlight element — sits behind items, transitions smoothly
    const hl = document.createElement('div');
    hl.id = 'cmd-highlight';
    list.prepend(hl);

    list.querySelectorAll<HTMLElement>('.cmd-item').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.index ?? '0');
        filtered[idx]?.action();
      });
      btn.addEventListener('mouseenter', () => {
        const idx = parseInt(btn.dataset.index ?? '0');
        setActive(idx);
      });
      btn.addEventListener('focus', () => {
        const idx = parseInt(btn.dataset.index ?? '0');
        setActive(idx);
      });
    });

    // Position highlight on first item without transition (snap, not slide)
    requestAnimationFrame(() => {
      const first = list.querySelector<HTMLElement>('.cmd-item.active');
      if (first) {
        hl.style.transition = 'none';
        hl.style.transform = `translateY(${first.offsetTop}px)`;
        hl.style.height = `${first.offsetHeight}px`;
        requestAnimationFrame(() => { hl.style.transition = ''; });
      }
    });
  }

  function itemHTML(cmd: Command, index: number, active: boolean): string {
    return `
      <button class="cmd-item${active ? ' active' : ''}" data-index="${index}" data-anim="${cmd.anim}">
        <span class="cmd-icon">${cmd.icon}</span>
        <span class="cmd-label">${cmd.label}</span>
        <span class="cmd-shortcut">${cmd.shortcut.map(k => `<kbd>${k}</kbd>`).join('')}</span>
      </button>
    `;
  }

  function setActive(index: number) {
    activeIndex = index;
    const list = getList();
    if (!list) return;
    list.querySelectorAll<HTMLElement>('.cmd-item').forEach(btn => {
      const idx = parseInt(btn.dataset.index ?? '-1');
      btn.classList.toggle('active', idx === activeIndex);
    });
    // Slide the highlight to the newly active item
    const activeBtn = list.querySelector<HTMLElement>('.cmd-item.active');
    const hl = list.querySelector<HTMLElement>('#cmd-highlight');
    if (activeBtn && hl) {
      hl.style.transform = `translateY(${activeBtn.offsetTop}px)`;
      hl.style.height = `${activeBtn.offsetHeight}px`;
    }
  }

  function move(dir: 1 | -1) {
    const filtered = getFiltered(getInput().value);
    const next = Math.max(0, Math.min(activeIndex + dir, filtered.length - 1));
    setActive(next);
    const activeBtn = getList()?.querySelector<HTMLElement>('.cmd-item.active');
    activeBtn?.focus();
    activeBtn?.scrollIntoView({ block: 'nearest' });
  }

  function executeActive() {
    getFiltered(getInput().value)[activeIndex]?.action();
  }

  // ── Per-page bindings: rebind to fresh palette nodes after each navigation ──
  function bindPaletteNodes() {
    isOpen = false;
    const input = getInput();
    const overlay = getOverlay();
    // dataset guard prevents double-binding if the same node persists
    if (input && !input.dataset.bound) {
      input.dataset.bound = '1';
      input.addEventListener('input', () => renderList(input.value));
    }
    if (overlay && !overlay.dataset.bound) {
      overlay.dataset.bound = '1';
      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    }
  }
  document.addEventListener('astro:page-load', bindPaletteNodes);

  // ── Global bindings: attached once to document, survive all navigations ──
  let gPressed = false;
  let gTimer: ReturnType<typeof setTimeout>;

  document.addEventListener('open-command-palette', () => open());

  document.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('#cmd-trigger')) {
      e.preventDefault();
      open();
    }
  });

  document.addEventListener('keydown', (e) => {
    const inInput = ['INPUT', 'TEXTAREA'].includes((e.target as HTMLElement).tagName);

    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      isOpen ? close() : open();
      return;
    }

    if (isOpen) {
      if (e.key === 'Escape')    { close(); return; }
      if (e.key === 'ArrowDown' || (e.key === 'Tab' && !e.shiftKey)) { e.preventDefault(); move(1); return; }
      if (e.key === 'ArrowUp'   || (e.key === 'Tab' && e.shiftKey))  { e.preventDefault(); move(-1); return; }
      if (e.key === 'Enter')     { e.preventDefault(); executeActive(); return; }
      return;
    }

    if (!inInput) {
      if (gPressed) {
        clearTimeout(gTimer);
        gPressed = false;
        const k = e.key.toUpperCase();
        const map: Record<string, string> = { H: '/', A: '/about', B: '/blog', W: '/work', C: '/cv', U: '/uses' };
        if (map[k]) { navigate(map[k]); return; }
      }
      if (e.key === 'g' && !e.metaKey && !e.ctrlKey) {
        gPressed = true;
        gTimer = setTimeout(() => { gPressed = false; }, 800);
        return;
      }
      if (e.key === 'l') { navigator.clipboard.writeText(window.location.href); showToast('Link copied!'); return; }
      if (e.key === 'e') { window.location.href = `mailto:${EMAIL}`; return; }
      if (e.key === 's') { window.open(GITHUB, '_blank'); return; }
    }
  });
</script>
