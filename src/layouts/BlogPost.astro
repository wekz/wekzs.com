---
import Layout from './Layout.astro';
import { SITE } from '@/config/site';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// BlogPosting structured data — lets Google show author, date and headline
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: SITE.name, url: Astro.site?.href },
  url: new URL(Astro.url.pathname, Astro.site).href,
};
---

<Layout title={`${title} — wekzs`} description={description} jsonLd={articleSchema}>
  <article class="post-article">
    <header>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="post-tag">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="post-prose">
      <slot />
    </div>
  </article>
  <a href="/blog" class="post-back">← All posts</a>
</Layout>
