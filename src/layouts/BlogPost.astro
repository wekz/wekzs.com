---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — wekzs`} description={description}>
  <article class="post-article">
    <header>
      <time>{formattedDate}</time>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="post-tag">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="post-prose">
      <slot />
    </div>
  </article>
  <a href="/blog" class="post-back">← All posts</a>
</Layout>
